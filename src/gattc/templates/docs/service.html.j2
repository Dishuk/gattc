{#- Macro for determining badge class based on role -#}
{%- macro badge_class(name) -%}
{%- set n = name|lower -%}
{%- if 'read' in n -%}badge-read
{%- elif 'write' in n -%}badge-write
{%- elif 'notify' in n or 'indicate' in n -%}badge-notify
{%- else -%}badge-other{%- endif -%}
{%- endmacro -%}

{#- Macro for rendering a single field's value cell -#}
{%- macro render_value_cell(field) -%}
{%- if field.bits -%}
<table class="values-table-inline">
{%- for bit in field.bits -%}
<tr><td class="value-code">{{ bit.range }}</td><td class="value-name">{{ bit.name }}</td></tr>
{%- endfor -%}
</table>
{%- elif field.values.type == "named" and field.values.items -%}
<table class="values-table-inline">
{%- for item in field.values.items -%}
<tr><td class="value-code">{{ item.value }}</td><td class="value-name">{{ item.name }}</td></tr>
{%- endfor -%}
</table>
{%- elif field.values.type in ["range", "text"] -%}
{{ field.values.display }}
{%- else -%}-{%- endif -%}
{%- endmacro -%}

{#- Macro for rendering a payload table -#}
{%- macro render_payload(payload, title) -%}
{%- if payload and payload.fields %}
                    <div class="payload-section">
                        <div class="payload-title">{{ title }}{% if payload.size %} ({{ payload.size }} bytes){% elif payload.is_variable %} (variable length){% endif %}</div>
                        <table>
                            <tr>
                                <th>Name</th>
                                <th>Offset</th>
                                <th>Length</th>
                                <th>Type</th>
                                <th>Description</th>
                                <th>Value</th>
                                <th>Units</th>
                            </tr>
{%- for field in payload.fields %}
                            <tr>
                                <td class="field-name">{{ field.name }}</td>
                                <td class="field-offset">{{ field.offset }}</td>
                                <td class="field-length">{{ field.length }}</td>
                                <td class="field-type">{{ field.type }}</td>
                                <td>{{ field.description or "-" }}</td>
                                <td class="field-value">{{ render_value_cell(field) }}</td>
                                <td class="field-unit">{{ field.unit or "-" }}</td>
                            </tr>
{%- if field.nested_fields %}
                            <tr>
                                <td colspan="7">
                                    <div class="nested-struct">
                                        <div class="nested-title">Struct:</div>
                                        <table>
                                            <tr>
                                                <th>Name</th>
                                                <th>Offset</th>
                                                <th>Length</th>
                                                <th>Type</th>
                                                <th>Description</th>
                                                <th>Value</th>
                                                <th>Units</th>
                                            </tr>
{%- for nested in field.nested_fields %}
                                            <tr>
                                                <td class="field-name">{{ nested.name }}</td>
                                                <td class="field-offset">{{ nested.offset }}</td>
                                                <td class="field-length">{{ nested.length }}</td>
                                                <td class="field-type">{{ nested.type }}</td>
                                                <td>{{ nested.description or "-" }}</td>
                                                <td class="field-value">{{ render_value_cell(nested) }}</td>
                                                <td class="field-unit">{{ nested.unit or "-" }}</td>
                                            </tr>
{%- endfor %}
                                        </table>
                                    </div>
                                </td>
                            </tr>
{%- endif -%}
{%- endfor %}
                        </table>
                    </div>
{%- endif -%}
{%- endmacro -%}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <style>
        :root {
            --primary-color: #2563eb;
            --secondary-color: #64748b;
            --border-color: #e2e8f0;
            --bg-light: #f8fafc;
            --bg-code: #f1f5f9;
            --bg-body: #ffffff;
            --text-primary: #1e293b;
            --text-secondary: #475569;
            --badge-read-bg: #dbeafe;
            --badge-read-text: #1d4ed8;
            --badge-write-bg: #dcfce7;
            --badge-write-text: #16a34a;
            --badge-notify-bg: #fef3c7;
            --badge-notify-text: #b45309;
            --badge-other-bg: #f3e8ff;
            --badge-other-text: #7c3aed;
            --hover-bg: rgba(37, 99, 235, 0.05);
            --active-bg: rgba(37, 99, 235, 0.1);
            --nav-width: {% if is_combined %}260px{% else %}220px{% endif %};
        }

        [data-theme="dark"] {
            --primary-color: #60a5fa;
            --secondary-color: #94a3b8;
            --border-color: #334155;
            --bg-light: #1e293b;
            --bg-code: #334155;
            --bg-body: #0f172a;
            --text-primary: #f1f5f9;
            --text-secondary: #94a3b8;
            --badge-read-bg: #1e3a5f;
            --badge-read-text: #93c5fd;
            --badge-write-bg: #14532d;
            --badge-write-text: #86efac;
            --badge-notify-bg: #451a03;
            --badge-notify-text: #fcd34d;
            --badge-other-bg: #3b0764;
            --badge-other-text: #d8b4fe;
            --hover-bg: rgba(96, 165, 250, 0.1);
            --active-bg: rgba(96, 165, 250, 0.15);
        }

        * { box-sizing: border-box; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            line-height: 1.6;
            color: var(--text-primary);
            margin: 0;
            padding: 0;
            background: var(--bg-body);
        }

        .layout { display: flex; min-height: 100vh; }

        .nav {
            width: var(--nav-width);
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            overflow-y: auto;
            background: var(--bg-light);
            border-right: 1px solid var(--border-color);
            padding: 1rem 0;
        }

        .nav-list { list-style: none; margin: 0; padding: 0; }
        .nav-item { margin: 0; }
        .nav-link:hover { color: var(--primary-color); background: var(--hover-bg); }
        .nav-link.active { color: var(--primary-color); border-left-color: var(--primary-color); background: var(--active-bg); font-weight: 500; }

        .content { margin-left: var(--nav-width); flex: 1; padding: 2rem 3rem; }

        h1 { color: var(--primary-color); border-bottom: 3px solid var(--primary-color); padding-bottom: 0.5rem; margin-bottom: 1rem; }
        h2 { color: var(--text-primary); margin-top: 2.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; }
        h3 { color: var(--primary-color); margin-top: 2rem; margin-bottom: 0.5rem; }

        .service-info { background: var(--bg-light); border: 1px solid var(--border-color); border-radius: 8px; padding: 1.5rem; margin-bottom: 2rem; }
        .service-info p { margin: 0.5rem 0; }
        .uuid { font-family: 'Consolas', 'Monaco', monospace; background: var(--bg-code); padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.9em; }

        .characteristic { border: 1px solid var(--border-color); border-radius: 8px; margin-bottom: 1.5rem; overflow: hidden; scroll-margin-top: 1rem; }
        .characteristic-header { background: var(--bg-light); padding: 1rem 1.5rem; border-bottom: 1px solid var(--border-color); }
        .characteristic-header h3 { margin: 0 0 0.75rem 0; }
        .characteristic-body { padding: 1.5rem; }
        .characteristic-meta { display: flex; flex-direction: column; gap: 0.4rem; font-size: 0.9em; }
        .meta-item { display: flex; align-items: center; gap: 0.5rem; }
        .meta-label { color: var(--text-secondary); font-weight: 500; min-width: 5.5rem; }

        .badge { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 4px; font-size: 0.8em; font-weight: 500; margin-right: 0.25rem; }
        .badge-read { background: var(--badge-read-bg); color: var(--badge-read-text); }
        .badge-write { background: var(--badge-write-bg); color: var(--badge-write-text); }
        .badge-notify { background: var(--badge-notify-bg); color: var(--badge-notify-text); }
        .badge-other { background: var(--badge-other-bg); color: var(--badge-other-text); }
        .characteristic-header .description { color: var(--text-secondary); margin: 0; }

        table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.9em; table-layout: fixed; }
        th, td { padding: 0.4rem 0.5rem; text-align: left; vertical-align: top; border-bottom: 1px solid var(--border-color); word-wrap: break-word; }
        th { background: var(--bg-light); font-weight: 600; color: var(--text-secondary); white-space: nowrap; }
        tr:hover { background: var(--bg-light); }

        th:nth-child(1), td:nth-child(1) { width: 12%; }
        th:nth-child(2), td:nth-child(2) { width: 6%; }
        th:nth-child(3), td:nth-child(3) { width: 7%; }
        th:nth-child(4), td:nth-child(4) { width: 10%; }
        th:nth-child(5), td:nth-child(5) { width: 25%; }
        th:nth-child(6), td:nth-child(6) { width: 30%; }
        th:nth-child(7), td:nth-child(7) { width: 10%; }

        .field-name { font-family: 'Consolas', 'Monaco', monospace; font-weight: 500; white-space: nowrap; }
        .field-offset, .field-length { font-family: 'Consolas', 'Monaco', monospace; text-align: center; white-space: nowrap; }
        .field-type { font-family: 'Consolas', 'Monaco', monospace; color: var(--primary-color); white-space: nowrap; }
        .field-value { font-family: 'Consolas', 'Monaco', monospace; color: var(--text-secondary); white-space: nowrap; }
        .field-unit { color: var(--secondary-color); white-space: nowrap; }

        .payload-section { margin-top: 1rem; }
        .payload-title { font-weight: 600; color: var(--text-secondary); margin-bottom: 0.5rem; font-size: 0.9em; text-transform: uppercase; letter-spacing: 0.05em; }

        .values-table-inline { width: auto; margin: 0; border: none; table-layout: auto; }
        .values-table-inline td:nth-child(1), .values-table-inline td:nth-child(2) { width: auto; }
        .values-table-inline tr, .values-table-inline tr:hover { background: none !important; }
        .values-table-inline td { padding: 0.1rem 0.5rem 0.1rem 0; border: none; }
        .values-table-inline .value-code { font-family: 'Consolas', 'Monaco', monospace; color: var(--secondary-color); padding-right: 0.3rem; }
        .values-table-inline .value-code::after { content: " ="; }
        .values-table-inline .value-name { font-family: 'Consolas', 'Monaco', monospace; color: var(--primary-color); }

        .nested-struct { margin: 0.5rem 0 0.5rem 1rem; }
        .nested-struct table { table-layout: fixed; }
        .nested-struct th, .nested-struct td { padding: 0.35rem 0.5rem; }
        .nested-title { font-size: 0.8em; color: var(--text-secondary); margin-bottom: 0.25rem; }

        footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--border-color); color: var(--text-secondary); font-size: 0.85em; text-align: center; }

        .theme-toggle-container { position: absolute; bottom: 1rem; left: 0; right: 0; display: flex; justify-content: center; align-items: center; gap: 0.5rem; font-size: 0.85em; }
        .theme-label { color: var(--text-secondary); font-weight: 500; }
        .theme-toggle { background: var(--bg-code); border: 1px solid var(--border-color); border-radius: 4px; padding: 0.2rem 0.5rem; cursor: pointer; font-size: 1em; color: var(--text-secondary); }
        .theme-toggle:hover { background: var(--hover-bg); color: var(--primary-color); }

        @media print {
            .nav { display: none; }
            .theme-toggle-container { display: none; }
            .content { margin-left: 0; max-width: none; padding: 1rem; }
            .characteristic { break-inside: avoid; }
{%- if is_combined %}
            .service-section { break-before: page; }
            .service-section:first-child { break-before: auto; }
{%- endif %}
        }

        @media (max-width: 900px) {
            .nav { display: none; }
            .content { margin-left: 0; }
        }
{% if is_combined %}
        .nav-header { padding: 0.5rem 1rem 1rem; border-bottom: 1px solid var(--border-color); margin-bottom: 0.5rem; }
        .nav-header h2 { margin: 0; font-size: 1em; color: var(--primary-color); }
        .nav-section { margin-bottom: 0.5rem; }
        .nav-service-title { font-size: 0.8em; font-weight: 600; color: var(--text-primary); padding: 0.5rem 1rem 0.25rem; margin: 0; cursor: pointer; display: flex; align-items: center; gap: 0.5rem; }
        .nav-service-title:hover { color: var(--primary-color); }
        .nav-service-title .arrow { font-size: 0.7em; transition: transform 0.2s ease; }
        .nav-service-title.collapsed .arrow { transform: rotate(-90deg); }
        .nav-title { font-size: 0.7em; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; padding: 0.3rem 1rem 0.3rem 1.5rem; margin: 0; }
        .nav-list.collapsed { display: none; }
        .nav-link { display: block; padding: 0.3rem 1rem 0.3rem 2rem; color: var(--text-secondary); text-decoration: none; font-size: 0.8em; border-left: 3px solid transparent; transition: all 0.15s ease; }
        .nav-link.service-link { padding-left: 1rem; font-weight: 500; color: var(--text-primary); }
        .service-section { margin-bottom: 4rem; scroll-margin-top: 1rem; }
{% else %}
        .nav-title { font-size: 0.75em; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; padding: 0.5rem 1rem; margin: 0; }
        .nav-link { display: block; padding: 0.4rem 1rem; color: var(--text-secondary); text-decoration: none; font-size: 0.85em; border-left: 3px solid transparent; transition: all 0.15s ease; }
{% endif %}
    </style>
</head>
<body>
    <div class="layout">
        <nav class="nav">
            <div class="theme-toggle-container">
                <span class="theme-label">Theme:</span>
                <button class="theme-toggle" id="theme-toggle" title="Toggle theme">&#9790;</button>
            </div>
{%- if is_combined %}
            <div class="nav-header">
                <h2>GATT Services</h2>
            </div>
{%- for svc in services %}
            <div class="nav-section">
                <h4 class="nav-service-title" data-service="{{ svc.service.name }}">
                    <span class="arrow">&#9660;</span>
                    <a href="#{{ svc.service.name }}" class="nav-link service-link">{{ svc.service.name }}</a>
                </h4>
                <ul class="nav-list" id="nav-{{ svc.service.name }}">
{%- for char in svc.characteristics %}
                    <li class="nav-item"><a href="#{{ svc.service.name }}-{{ char.name }}" class="nav-link">{{ char.name }}</a></li>
{%- endfor %}
                </ul>
            </div>
{%- endfor %}
{%- else %}
            <h4 class="nav-title">Characteristics</h4>
            <ul class="nav-list">
{%- for char in services[0].characteristics %}
                <li class="nav-item"><a href="#{{ char.name }}" class="nav-link">{{ char.name }}</a></li>
{%- endfor %}
            </ul>
{%- endif %}
        </nav>

        <main class="content">
            <h1>{{ title }}</h1>
{%- for svc in services %}
{%- if is_combined %}

            <section class="service-section" id="{{ svc.service.name }}">
                <h2>{{ svc.service.name }}</h2>
{%- endif %}

            <div class="service-info">
                <p><strong>UUID:</strong> <span class="uuid">{{ svc.service.uuid }}</span></p>
{%- if svc.service.description %}
                <p class="description">{{ svc.service.description }}</p>
{%- endif %}
            </div>

            <h{% if is_combined %}3{% else %}2{% endif %}>Characteristics</h{% if is_combined %}3{% else %}2{% endif %}>
{%- for char in svc.characteristics %}

            <div class="characteristic" id="{% if is_combined %}{{ svc.service.name }}-{% endif %}{{ char.name }}">
                <div class="characteristic-header">
                    <h3>{{ char.name }}</h3>
                    <div class="characteristic-meta">
                        <div class="meta-item">
                            <span class="meta-label">UUID:</span>
                            <span class="uuid">{{ char.uuid }}</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Properties:</span>
{%- for prop in char.properties %} <span class="badge {{ badge_class(prop) }}">{{ prop }}</span>{%- endfor %}
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Permissions:</span>
{%- for perm in char.permissions %} <span class="badge {{ badge_class(perm) }}">{{ perm }}</span>{%- endfor %}
                        </div>
{%- if char.description %}
                        <p class="description">{{ char.description }}</p>
{%- endif %}
                    </div>
                </div>

                <div class="characteristic-body">
{{- render_payload(char.payload, "Payload") -}}
{{- render_payload(char.read_payload, "Read Payload") -}}
{{- render_payload(char.write_payload, "Write Payload") -}}
{{- render_payload(char.notify_payload, "Notify Payload") -}}
{%- if not char.payload and not char.read_payload and not char.write_payload and not char.notify_payload %}
                    <p style="color: var(--text-secondary); font-style: italic;">No payload defined</p>
{%- endif %}
                </div>
            </div>
{%- endfor %}
{%- if is_combined %}
            </section>
{%- endif %}
{%- endfor %}

            <footer>Generated by gattc</footer>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const toggle = document.getElementById('theme-toggle');
            const setTheme = (dark) => {
                document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
                toggle.textContent = dark ? '\u2600' : '\u263E';
                localStorage.setItem('theme', dark ? 'dark' : 'light');
            };
            setTheme(localStorage.getItem('theme') === 'dark');
            toggle.addEventListener('click', () => setTheme(document.documentElement.getAttribute('data-theme') !== 'dark'));
{% if is_combined %}
            document.querySelectorAll('.nav-service-title').forEach(title => {
                title.addEventListener('click', function(e) {
                    if (e.target.classList.contains('nav-link')) return;
                    document.getElementById('nav-' + this.dataset.service).classList.toggle('collapsed');
                    this.classList.toggle('collapsed');
                });
            });
            const navLinks = document.querySelectorAll('.nav-link:not(.service-link)');
            const serviceLinks = document.querySelectorAll('.nav-link.service-link');
            const chars = document.querySelectorAll('.characteristic');
            const sections = document.querySelectorAll('.service-section');
            function updateActiveLink() {
                const scrollPos = window.scrollY + 100;
                let currentChar = '', currentService = '';
                chars.forEach(c => { if (scrollPos >= c.offsetTop && scrollPos < c.offsetTop + c.offsetHeight) currentChar = c.id; });
                sections.forEach(s => { if (scrollPos >= s.offsetTop && scrollPos < s.offsetTop + s.offsetHeight) currentService = s.id; });
                if ((window.innerHeight + window.scrollY) >= document.body.offsetHeight - 50) {
                    if (chars.length) currentChar = chars[chars.length - 1].id;
                    if (sections.length) currentService = sections[sections.length - 1].id;
                }
                navLinks.forEach(l => l.classList.toggle('active', l.getAttribute('href') === '#' + currentChar));
                serviceLinks.forEach(l => l.classList.toggle('active', l.getAttribute('href') === '#' + currentService));
            }
{% else %}
            const navLinks = document.querySelectorAll('.nav-link');
            const sections = document.querySelectorAll('.characteristic');
            function updateActiveLink() {
                const scrollPos = window.scrollY + 100;
                let current = '';
                sections.forEach(s => { if (scrollPos >= s.offsetTop && scrollPos < s.offsetTop + s.offsetHeight) current = s.id; });
                if ((window.innerHeight + window.scrollY) >= document.body.offsetHeight - 50) current = sections[sections.length - 1].id;
                navLinks.forEach(l => l.classList.toggle('active', l.getAttribute('href') === '#' + current));
            }
{% endif %}
            window.addEventListener('scroll', updateActiveLink);
            updateActiveLink();
        });
    </script>
</body>
</html>
