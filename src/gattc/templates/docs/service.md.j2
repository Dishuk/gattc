{#- Escape pipes and collapse newlines in table cells -#}
{%- macro cell(text) -%}
{{ (text or "-") | string | replace("|", "\\|") | replace("\n", " ") }}
{%- endmacro -%}

{#- Short marker for the Value column; complex values point to numbered appendices -#}
{%- macro value_marker(field) -%}
{%- if field.bits -%}see Table {{ field.bits_table }}
{%- elif field["values"].type == "named" and field["values"]["items"] -%}see Table {{ field.values_table }}
{%- elif field["values"].type == "range" -%}{{ field["values"].display }}
{%- elif field["values"].type == "text" -%}{{ cell(field["values"].display) }}
{%- elif field.nested_fields -%}see Table {{ field.struct_table }}
{%- else -%}-{%- endif -%}
{%- endmacro -%}

{#- Change-status suffix/wrapper on a name -#}
{%- macro name_with_status(name, status) -%}
{%- if status == 'added' -%}{{ name }} **[NEW]**
{%- elif status == 'modified' -%}{{ name }} **[CHANGED]**
{%- elif status == 'removed' -%}~~{{ name }}~~
{%- else -%}{{ name }}{%- endif -%}
{%- endmacro -%}

{#- A single field row in a payload table -#}
{%- macro field_row(field) -%}
| `{{ name_with_status(field.name, field.change_status) }}` | {{ field.offset }} | {{ field.length }} | `{{ field.type }}` | {{ cell(field.description) }} | {{ value_marker(field) }} | {{ cell(field.unit) }} |
{% endmacro -%}

{#- Sub-tables for complex field detail (bits / enum / nested struct) -#}
{%- macro field_detail(field) -%}
{%- if field.bits %}

#### Table {{ field.bits_table }} — `{{ field.name }}` bitfield
| Range | Name |
|-------|------|
{% for bit in field.bits -%}
| `{{ bit.range }}` | `{{ bit.name }}` |
{% endfor -%}
{%- elif field["values"].type == "named" and field["values"]["items"] %}

#### Table {{ field.values_table }} — `{{ field.name }}` enum values
| Value | Name |
|-------|------|
{% for item in field["values"]["items"] -%}
| `{{ item.value }}` | `{{ item.name }}` |
{% endfor -%}
{%- endif -%}
{%- if field.nested_fields %}

#### Table {{ field.struct_table }} — `{{ field.name }}` struct layout
| Name | Offset | Length | Type | Description | Value | Units |
|------|--------|--------|------|-------------|-------|-------|
{% for nested in field.nested_fields -%}
{{ field_row(nested) -}}
{% endfor -%}
{%- for nested in field.nested_fields -%}
{{ field_detail(nested) -}}
{%- endfor -%}
{%- endif -%}
{%- endmacro -%}

{#- A complete payload section: main table + detail sub-tables -#}
{%- macro render_payload(payload, title) -%}
{%- if payload and payload.fields %}

#### {{ title }}{% if payload.size %} ({{ payload.size }} byte{% if payload.size != 1 %}s{% endif %}){% elif payload.is_variable %} (variable length){% endif %}
| Name | Offset | Length | Type | Description | Value | Units |
|------|--------|--------|------|-------------|-------|-------|
{% for field in payload.fields -%}
{{ field_row(field) -}}
{% endfor -%}
{%- for field in payload.fields -%}
{{ field_detail(field) -}}
{%- endfor -%}
{%- endif -%}
{%- endmacro -%}

{#- Format a characteristic reference with its index (N.M in combined, N. in single) -#}
{%- macro char_ref(svc, svc_idx, name) -%}
{%- set idx = svc.char_index.get(name) -%}
{%- if idx and is_combined -%}`{{ svc_idx }}.{{ idx }} {{ name }}`
{%- elif idx -%}`{{ idx }}. {{ name }}`
{%- else -%}`{{ name }}`{%- endif -%}
{%- endmacro -%}

{#- Map a raw "Service X changed" string to a short row label -#}
{%- macro _service_label(text) -%}
{%- set t = text|lower -%}
{%- if "description" in t -%}Description
{%- elif "uuid" in t -%}UUID
{%- elif "name" in t -%}Name
{%- else -%}{{ text }}{%- endif -%}
{%- endmacro -%}

{#- Render the Change|Detail table for service-level changes (includes added/removed chars) -#}
{%- macro render_service_table(svc, svc_idx, service_changes, schema_revision, added, removed) -%}
| Change | Detail |
|--------|--------|
{% for change in service_changes -%}
{%- set label = _service_label(change) -%}
| {{ label }} {% if label == "Description" %}updated{% else %}changed{% endif %} | — |
{% endfor -%}
{% if schema_revision is defined -%}
| Schema revision | `{{ schema_revision.old|default('none') }}` → `{{ schema_revision.new|default('none') }}` |
{% endif -%}
{% for idx, name in added -%}
| Characteristic added | {{ char_ref(svc, svc_idx, name) }} |
{% endfor -%}
{% for name in removed -%}
| Characteristic removed | `{{ name }}` |
{% endfor -%}
{%- endmacro -%}

{#- Render the Change|Detail table for one modified characteristic -#}
{%- macro render_mods_table(mods) -%}
| Change | Detail |
|--------|--------|
{% if mods.uuid is defined -%}
| UUID changed | `{{ mods.uuid.old }}` → `{{ mods.uuid.new }}` |
{% endif -%}
{% if mods.description_changed -%}
| Description updated | — |
{% endif -%}
{% if mods.payload_config_changed -%}
| Payload config updated | — |
{% endif -%}
{% for prop in mods.properties_added|default([]) -%}
| Property added | `{{ prop }}` |
{% endfor -%}
{% for prop in mods.properties_removed|default([]) -%}
| Property removed | `{{ prop }}` |
{% endfor -%}
{% for perm in mods.permissions_added|default([]) -%}
| Permission added | `{{ perm }}` |
{% endfor -%}
{% for perm in mods.permissions_removed|default([]) -%}
| Permission removed | `{{ perm }}` |
{% endfor -%}
{% for fld in mods.fields_added|default([]) -%}
| Field added | `{{ fld.name }}`{% if fld.type %} (`{{ fld.type }}`){% endif %} |
