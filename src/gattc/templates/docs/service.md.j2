{% for fld in mods.fields_removed|default([]) -%}
| Field removed | `{{ fld }}` |
{% endfor -%}
{% for fld in mods.fields_modified|default([]) -%}
| Field changed | `{{ fld.name }}`{% if fld.detail %} ({{ fld.detail|replace("->", "→") }}){% endif %} |
{% endfor -%}
{% if mods.offsets_changed -%}
| Payload offsets changed | — |
{% endif -%}
{%- endmacro -%}

